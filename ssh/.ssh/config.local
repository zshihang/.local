# host-specific entries go here

# OrbStack 'orb' SSH host for Linux machines (auto-installed; was at the top of
# ~/.ssh/config but moved here to keep the public dotfile machine-agnostic).
Include ~/.orbstack/ssh/config

Host nas.sea.zsh.fm
  Port 29
  RequestTTY yes
  SetEnv TERM=xterm-256color
  RemoteCommand stty sane; exec bash --login
Include /Users/zsh/.colima/ssh_config
