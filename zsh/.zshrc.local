export SANDBOX_NAME="zshihang-gke-sandbox"
export SANDBOX_LOCATION="us-central1-c"
export DEV_PROJECT=zshihang-gke-dev
export GKE_DEV_PROJECT=zshihang-gke-dev
export HOSTED_MASTER_PROJECT=gke-zshihang-hosted-master
export GKE_HOSTED_MASTER_PROJECT=gke-zshihang-hosted-master

# PATH
export PATH="/usr/local/google/home/zshihang/.local/bin:$PATH"
export PATH="/usr/lib/cargo/bin:$PATH"
export PATH="$PATH:/usr/local/google/home/zshihang/workplace/dotnet"
export PATH="/usr/local/google/home/zshihang/workplace/go/src/k8s.io/kubernetes/third_party/etcd:${PATH}"

#------------------------------------------------------------------------------
#------------------------------------------------------------------------------
# ## COMPLETIONS #
#------------------------------------------------------------------------------

zstyle ':completion::complete:*' use-cache 1
zstyle ':completion::complete:*' cache-path ~/.zsh/cache
zstyle ':completion:*' users root $USER #fix lag in google3

source /etc/bash_completion.d/jjd

# p4
if [[ -f /etc/bash_completion.d/g4d ]]; then
  . /etc/bash_completion.d/p4
  . /etc/bash_completion.d/g4d
fi

# fig
if [[ -f /etc/bash_completion.d/hgd ]]; then
  source /etc/bash_completion.d/hgd
fi

# blaze
if [ -d /google/data ]; then
  fpath=(/google/src/files/head/depot/google3/devtools/blaze/scripts/zsh_completion $fpath)
fi

