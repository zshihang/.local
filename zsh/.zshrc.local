#------------------------------------------------------------------------------
#------------------------------------------------------------------------------
# ## FUNCTIONS #
#------------------------------------------------------------------------------

function bb() {
  if [[ $PWD =~ '(.*)/blaze-bin(.*)' ]]; then
    cd "${match[1]}${match[2]}"
  else
    cd "${PWD/\/google3//google3/blaze-bin}"
  fi
}

# piper
function tmux_title() {
  if [[ $PWD =~ /google/src/cloud/[^/]+/([^/]+)/.* ]]; then
    printf "\ek${match[1]}\e\\"
  else
    printf "\ek$(basename `pwd`)\e\\"
  fi
}
if [[ ! -z "$TMUX" ]]; then
  precmd_functions+=(tmux_title)
fi

#------------------------------------------------------------------------------
#------------------------------------------------------------------------------
# ## FZF #
#------------------------------------------------------------------------------

export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git . \'$SEARCH_REL_PATH\'"

# For "workon"
export VIRTUALENVWRAPPER_PYTHON=/usr/bin/python3
source /usr/share/virtualenvwrapper/virtualenvwrapper.sh
